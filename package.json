{
  "name": "cascade-ai",
  "version": "0.2.12",
  "description": "Multi-tier AI orchestration CLI — T1/T2/T3 hierarchical agent system",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "cascade": "bin/cascade.js"
  },
  "workspaces": [
    "web"
  ],
  "scripts": {
    "build:web": "npm run build -w web",
    "build:cli": "tsup",
    "build": "npm run build:web && npm run build:cli",
    "dev": "tsup --watch",
    "dev:web": "npm run dev -w web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "cascade": "node bin/cascade.js"
  },
  "files": [
    "dist",
    "bin",
    "web/dist",
    "completions",
    "README.md"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "1.13.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "dayjs": "^1.11.13",
    "diff": "^7.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "glob": "^13.0.6",
    "highlight.js": "^11.10.0",
    "ignore": "^6.0.2",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^13.0.0",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "openai": "^4.67.0",
    "ora": "^8.1.0",
    "pdfkit": "^0.18.0",
    "posthog-node": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.0",
    "socket.io-msgpack-parser": "^3.0.2",
    "undici": "^6.21.0",
    "update-notifier": "^7.3.0",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0",
    "playwright": "^1.48.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^5.2.3",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "agent",
    "orchestration",
    "multi-agent",
    "llm",
    "anthropic",
    "openai",
    "gemini",
    "ollama"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Varun-SV/Cascade-AI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Varun-SV/Cascade-AI.git"
  },
  "bugs": {
    "url": "https://github.com/Varun-SV/Cascade-AI/issues"
  },
  "overrides": {
    "node-domexception": "npm:domexception@^4.0.0"
  }
}