# Cascade Cloud server — copy to .env and fill in for local development.

PORT=8787
SESSION_SECRET=change-me-to-a-long-random-string
DATA_DIR=./data
WEB_ORIGIN=http://localhost:5173
OAUTH_REDIRECT_BASE_URL=http://localhost:8787

# GitHub OAuth App (github.com/settings/developers)
# Callback URL: <OAUTH_REDIRECT_BASE_URL>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth Client (console.cloud.google.com/apis/credentials)
# Callback URL: <OAUTH_REDIRECT_BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to 1 to enable POST /auth/dev-login, a local-only login shortcut that
# skips real OAuth. Never set this in a real deployment.
CLOUD_DEV_BYPASS=0

# Razorpay recurring subscriptions (dashboard.razorpay.com). All optional —
# billing is disabled and the Upgrade page shows "not configured" until
# KEY_ID + KEY_SECRET + PLAN_ID are set. Use rzp_test_* keys + a test Plan for
# development; swap to live keys only in the production deployment. KEY_SECRET
# and WEBHOOK_SECRET are server-only and must never be exposed to the client.
#   - PLAN_ID: create a recurring Plan in the Razorpay dashboard, then paste its id.
#   - WEBHOOK_SECRET: set on the Razorpay webhook (Settings → Webhooks) pointed at
#     <OAUTH_REDIRECT_BASE_URL>/api/billing/webhook, subscribing to subscription.* events.
#   - PRICE_LABEL: display-only text on the Upgrade page (the real price lives on the Plan).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_PRICE_LABEL=₹499 / month
