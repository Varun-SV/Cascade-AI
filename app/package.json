{
  "name": "cascade-ai-desktop",
  "version": "0.12.20",
  "description": "Cascade AI \u2014 purpose-built desktop application",
  "author": "Varun SV",
  "homepage": "https://github.com/Varun-SV/Cascade-AI",
  "license": "MIT",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "predev": "npm --prefix .. run build:cli",
    "dev": "cross-env ELECTRON_DEV=1 concurrently -k \"vite\" \"electron .\"",
    "gen:icon": "node build-icon.cjs",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "cascade-ai": "*",
    "@monaco-editor/react": "^4.6.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@reduxjs/toolkit": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.1.0",
    "reactflow": "^11.11.0",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.5.0",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.460.0",
    "socket.io-client": "^4.8.0",
    "socket.io-msgpack-parser": "^3.0.2",
    "electron-updater": "^6.3.0",
    "node-pty": "^1.0.0",
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0"
  }
}
